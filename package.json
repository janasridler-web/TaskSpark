{
  "name": "taskspark",
  "version": "4.2.0",
  "description": "TaskSpark — Focus · Flow · Finish",
  "main": "src/main.js",
  "scripts": {
    "setup": "node setup.js",
    "start": "node setup.js && electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir",
    "build:mac": "electron-builder --mac",
    "build:mac:dir": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.taskspark.app",
    "productName": "TaskSpark",
    "publish": {
      "provider": "github",
      "owner": "janasridler-web",
      "repo": "taskspark-releases"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/taskspark.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "TaskSpark.Setup.exe"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/taskspark.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "artifactName": "TaskSpark-${arch}.${ext}"
    },
    "files": [
      "src/**/*",
      "web/**/*",
      "assets/**/*",
      "!**/test/**",
      "!**/tests/**",
      "!**/*.md",
      "!**/*.map"
    ]
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.6.2"
  },
  "author": {
    "name": "Jana Sridler",
    "email": "janasridler@gmail.com",
    "url": "https://taskspark.tech"
  }
}
